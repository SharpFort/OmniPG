# ==============================================================================
# 零后端代码统一管理后台 — 生产环境配置
# 此文件包含生产（Production）环境的配置
# 所有敏感值通过环境变量或密钥管理服务注入
# ==============================================================================

# ------------------------------------------------------------------------------
# 应用基础
# ------------------------------------------------------------------------------
APP_ENV=production
APP_NAME=zero-backend-rbac
APP_DEBUG=false

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
PG_PORT=5432
DB_PASSWORD=${DB_PASSWORD}  # 通过环境变量或 Vault 注入
DB_USER=app_owner
DB_NAME=app_db

# ------------------------------------------------------------------------------
# Pgbouncer 连接池
# ------------------------------------------------------------------------------
PG_BOUNCER_PORT=5433
AUTHENTICATOR_PASSWORD=${AUTHENTICATOR_PASSWORD}  # 通过环境变量注入

# ------------------------------------------------------------------------------
# APISIX
# ------------------------------------------------------------------------------
APISIX_HTTP_PORT=9080
APISIX_HTTPS_PORT=9443
APISIX_ADMIN_PORT=9180
APISIX_ADMIN_KEY=${APISIX_ADMIN_KEY}  # 通过环境变量注入

# ------------------------------------------------------------------------------
# PostgREST
# ------------------------------------------------------------------------------
PGRST_PORT=3000

# JWT Secret：生产环境使用 Casdoor JWKS RS256 公钥
JWKS_JSON=${JWKS_JSON}  # 通过环境变量注入

# ------------------------------------------------------------------------------
# Casdoor
# ------------------------------------------------------------------------------
CASDOOR_PORT=8000
CASDOOR_DB_PASSWORD=${CASDOOR_DB_PASSWORD}  # 通过环境变量注入
CASDOOR_ENDPOINT=${CASDOOR_ENDPOINT}
CASDOOR_CLIENT_ID=${CASDOOR_CLIENT_ID}
CASDOOR_CLIENT_SECRET=${CASDOOR_CLIENT_SECRET}

# ------------------------------------------------------------------------------
# etcd
# ------------------------------------------------------------------------------
ETCD_PORT=2379

# ------------------------------------------------------------------------------
# Swagger UI
# ------------------------------------------------------------------------------
SWAGGER_PORT=8080

# ------------------------------------------------------------------------------
# 前端开发
# ------------------------------------------------------------------------------
VITE_APP_PORT=5173

# ------------------------------------------------------------------------------
# RLS 租户配置
# ------------------------------------------------------------------------------
DEFAULT_TENANT_ID=tenant_default
